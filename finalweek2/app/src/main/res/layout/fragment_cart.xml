    android:orientation="vertical"
    android:padding="20dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/bagcircle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
